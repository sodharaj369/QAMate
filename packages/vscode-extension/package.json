  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean"
  },
  "dependencies": {
    "@qamate/engine": "*",
    "@qamate/shared": "*"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0"
  }
