{
  "name": "@qamate/vscode-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "engines": {
    "vscode": "^1.75.0"
  },
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "qamate.analyze",
        "title": "QAMate: Analyze Active Requirement File"
      }
    ]
